<!-- Lua start -->
<controls:FancyWindow xmlns="https://spacestation14.io"
                      xmlns:gfx="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
                      xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
                      xmlns:ui="clr-namespace:Content.Client.Shuttles.UI"
                      xmlns:luaShipyard="clr-namespace:Content.Client._Lua.Shipyard.UI"
                      MinSize="1210 675">
    <BoxContainer Orientation="Vertical">
        <BoxContainer Orientation="Horizontal" Margin="3 0" HorizontalExpand="True" VerticalExpand="True">
            <BoxContainer Orientation="Vertical" Margin="2 3 0 3">
                <BoxContainer Orientation="Horizontal" VerticalExpand="True" Margin="3 0">
                    <BoxContainer Orientation="Vertical" >
                        <BoxContainer Orientation="Horizontal">
                            <Label Text="{Loc 'bank-atm-menu-balance-label'}" FontColorOverride="Silver"/>
                            <Label Name="BalanceLabel" Text="{Loc 'shipyard-console-no-bank'}" />
                        </BoxContainer>
                        <BoxContainer Orientation="Horizontal">
                            <Label Text="{Loc 'shipyard-console-appraisal-label'}" FontColorOverride="Silver"/>
                            <Label Name="ShipAppraisalLabel" Text="{Loc 'shipyard-console-no-deed'}" />
                        </BoxContainer>
                        <Label Text="{Loc 'shipyard-console-deed-label'}" FontColorOverride="Silver"/>
                        <BoxContainer Orientation="Horizontal">
                            <Label Text="•"/>
                            <Label Name="DeedTitle" Margin="5 0"/>
                        </BoxContainer>
                    </BoxContainer>
                </BoxContainer>
                <BoxContainer Orientation="Vertical"
                              Name="NoDeedHelperContainer"
                              VerticalExpand="True"
                              Margin="3 0">
                    <Label Text="{Loc 'shipyard-console-no-idcard-helper-line1'}" FontColorOverride="Silver"/>
                    <Label Text="{Loc 'shipyard-console-no-idcard-helper-line2'}" FontColorOverride="Silver"/>
                </BoxContainer>
                <BoxContainer Orientation="Horizontal" VerticalExpand="True"/>
                <BoxContainer Orientation="Horizontal"
                              Name="RenameContainer"
                              VerticalAlignment="Bottom"
                              HorizontalExpand="True"
                              Visible="False">
                    <LineEdit Name="RenameLineEdit"
                              HorizontalExpand="True"
                              PlaceHolder="{Loc 'shipyard-console-rename-placeholder'}"
                              Editable="False"/>
                    <Button Name="RenameButton"
                            Margin="3 0 0 0"
                            HorizontalAlignment="Right"
                            Text="{Loc 'shipyard-console-rename-button'}"
                            Disabled="True"/>
                </BoxContainer>
                <BoxContainer Orientation="Horizontal"
                              VerticalAlignment="Bottom"
                              HorizontalExpand="True"
                              Margin="0 3">
                    <Button Name="TargetIdButton"
                            VerticalExpand="True"
                            HorizontalExpand="True"
                            Access="Public"
                            Text="{Loc 'id-card-console-window-insert-button'}"/>
                    <controls:ConfirmButton Name="SellShipButton"
                                            VerticalExpand="True"
                                            HorizontalExpand="True"
                                            Text="{Loc 'cargo-pallet-sell-button'}"
                                            ConfirmationText="{Loc 'admin-notes-delete-confirm'}"
                                            Disabled="True"/>
                    <controls:ConfirmButton Name="UnassignDeedButton"
                                            VerticalExpand="True"
                                            HorizontalExpand="True"
                                            Text="{Loc 'shipyard-console-unassign-deed'}"
                                            ConfirmationText="{Loc 'admin-notes-delete-confirm'}"
                                            Disabled="True"/>
                </BoxContainer>
                <PanelContainer VerticalAlignment="Bottom" HorizontalExpand="True" VerticalExpand="True">
                    <luaShipyard:ShipyardDockRadarControl Name="DockRadar" MinSize="400 400"/>
                    <PanelContainer.PanelOverride>
                        <gfx:StyleBoxFlat BorderColor="#444444" BorderThickness="2"/>
                    </PanelContainer.PanelOverride>
                </PanelContainer>
            </BoxContainer>
            <BoxContainer Orientation="Vertical"
                          HorizontalExpand="True"
                          VerticalExpand="True"
                          Margin="5 1 1 0">
                <BoxContainer Orientation="Horizontal">
                    <LineEdit Name="SearchBar"
                              PlaceHolder="{Loc 'cargo-console-menu-search-bar-placeholder'}"
                              HorizontalExpand="True"/>
                </BoxContainer>
                <BoxContainer Orientation="Horizontal" Margin="0 2 0 0">
                    <OptionButton Name="Categories"
                                  Prefix="{Loc 'shipyard-console-menu-size-label'}"
                                  HorizontalExpand="True"/>
                    <OptionButton Name="Classes"
                                  Prefix="{Loc 'shipyard-console-menu-class-label'}"
                                  HorizontalExpand="True"/>
                    <OptionButton Name="Engines"
                                  Prefix="{Loc 'shipyard-console-menu-engine-label'}"
                                  HorizontalExpand="True"/>
                </BoxContainer>
                <ScrollContainer HorizontalExpand="True"
                                 VerticalExpand="True"
                                 Margin="0 3"
                                 SizeFlagsStretchRatio="6">
                    <BoxContainer Name="Vessels"
                                  Orientation="Vertical"
                                  HorizontalExpand="True"
                                  VerticalExpand="True">
                        <!-- Vessels get added here by code -->
                    </BoxContainer>
                </ScrollContainer>
            </BoxContainer>
        </BoxContainer>
        <BoxContainer Orientation="Vertical" Margin="0 2 0 0">
            <PanelContainer StyleClasses="LowDivider"/>
            <BoxContainer Orientation="Horizontal"
                          Margin="10 2 5 0"
                          VerticalAlignment="Bottom">
                <Label Text="{Loc 'shipyard-console-hint'}"
                       StyleClasses="WindowFooterText"
                       HorizontalAlignment="Left"
                       Margin="0 0 5 0" />
                <Label Text="{Loc 'shipyard-console-version'}"
                       StyleClasses="WindowFooterText"
                       HorizontalAlignment="Right"
                       HorizontalExpand="True"
                       Margin="0 0 5 0" />
                <TextureRect StyleClasses="NTLogoDark"
                             Stretch="KeepAspectCentered"
                             VerticalAlignment="Center"
                             HorizontalAlignment="Right"
                             SetSize="19 19"/>
            </BoxContainer>
        </BoxContainer>
    </BoxContainer>
</controls:FancyWindow>
<!-- Lua end -->
